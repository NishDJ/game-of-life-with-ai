# Conway's Game of Life with AI - Environment Configuration

# JWT Secret Key (IMPORTANT: Change this in production!)
# Generate a secure random string for production use
JWT_SECRET=your-super-secret-jwt-key-here-change-this-in-production

# Server Configuration
PORT=3000

# Game Configuration (optional - these are defaults)
# MAX_GRID_SIZE=200
# DEFAULT_GRID_WIDTH=100
# DEFAULT_GRID_HEIGHT=75
# GAME_CLEANUP_INTERVAL=900000

# AI Configuration (optional)
# AI_PREDICTION_MAX_GENERATIONS=20
# AI_ANALYSIS_TIMEOUT=30000

# Development Settings
# NODE_ENV=development
# LOG_LEVEL=info